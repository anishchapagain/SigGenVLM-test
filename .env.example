# GenSigLLM Configuration

# App Config
PROJECT_NAME="GenSigLLM API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# DB Config
DATABASE_URL=postgresql://gensig_user:strongpassword@localhost:5432/gensigllm

# Security
SECRET_KEY="change_this_to_a_secure_random_string_in_production"

# Validation
MAX_IMAGE_SIZE_MB=5
MIN_IMAGE_SIZE_KB=2

IMAGE_FILE_TYPE_I=JPEG
IMAGE_FILE_TYPE_II=PNG

PROJECT_DESCRIPTION="Generative AI forensic signature verification system API."

# DB Config
DATABASE_URL=postgresql://postgres:password@localhost:5432/sig_verification_llm

# Security
SECRET_KEY="super_secret_local_development_key"

OLLAMA_MODEL_NAME=qwen2.5vl:7b # Tuned 
OLLAMA_BASE_URL=http://localhost:11434

# AI Configuration
PRIMARY_LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_MODEL_NAME=gpt-4o
GEMINI_MODEL_NAME=gemini-1.5-pro-latest

OLLAMA_MODEL_NAME=qwen2.5-vl
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.2-11b-vision-preview
LLM_TIMEOUT_SECONDS=30
FALLBACK_RETRY_ATTEMPTS=2
CHARACTERISTICS_FORMAT=verbose
